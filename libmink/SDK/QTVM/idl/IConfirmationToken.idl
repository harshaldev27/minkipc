/** @file IConfirmationToken.idl  */

/**
 * @addtogroup IConfirmationToken
 * @{
 */
interface IConfirmationToken {

  /**
   * Sign the passed token with HMAC key
   * and return the mac.
   */
  method signConfirmationToken(in buffer token, out buffer mac);
   /** @} */ /* end_addtogroup IConfirmationToken */
};
